{
  "speaker": {
	"name": "Old Man",
	"portrait": "res://portraits/old_man.png"
  },

  "start": "default_intro",

  "start_rules": [
	{
	  "conditions": [
        "key_already_given"
	  ],
	  "start": "after_quest_intro"
	},
	{
	  "conditions": [
		"quest_1_active",
        "has_old_key"
	  ],
	  "start": "key_found_intro"
	},
	{
	  "conditions": [
        "quest_1_active"
	  ],
	  "start": "quest_intro"
	}
  ],

  "nodes": {
	"default_intro": {
	  "text": "Hello, {player_name}. Nice weather today.",
	  "choices": [
		{
		  "text": "Leave.",
		  "next": "leave"
		}
	  ]
	},

	"quest_intro": {
	  "text": "Have you found my old key yet?",
	  "choices": [
		{
		  "text": "Not yet.",
		  "next": "not_found"
		},
		{
		  "text": "Leave.",
		  "next": "leave"
		}
	  ]
	},

	"key_found_intro": {
	  "text": "Is that my old key in your hand?",
	  "choices": [
		{
		  "text": "Give the old key.",
		  "next": "give_key",
		  "conditions": [
			"has_old_key",
            "!key_already_given"
		  ]
		},
		{
		  "text": "Keep it for now.",
		  "next": "keep_key"
		}
	  ]
	},

	"after_quest_intro": {
	  "text": "Thanks again for bringing my key back.",
	  "choices": [
		{
		  "text": "You're welcome.",
		  "next": "welcome"
		},
		{
		  "text": "Leave.",
		  "next": "leave"
		}
	  ]
	},

	"give_key": {
	  "text": "You found it. Thank you.",
	  "events": [
		"old_key_given",
        "quest_1_completed"
	  ],
	  "end": true
	},

	"not_found": {
	  "text": "Please keep looking. It must be somewhere nearby.",
	  "end": true
	},

	"keep_key": {
	  "text": "Why are you holding onto it?",
	  "end": true
	},

	"welcome": {
	  "text": "I won't forget what you did.",
	  "end": true
	},

	"leave": {
	  "text": "Take care.",
	  "end": true
	}
  }
}
