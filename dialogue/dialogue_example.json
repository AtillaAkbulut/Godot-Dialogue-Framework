{
  "speaker": {
	"name": "Old Man",
	"portrait": "res://portraits/old_man.png"
  },

  "start": "first_meeting",

  "start_rules": [
	{
	  "conditions": [
        "old_key_quest_completed"
	  ],
	  "start": "quest_completed_intro"
	},
	{
	  "conditions": [
		"old_key_quest_active",
        "has_old_key"
	  ],
	  "start": "key_found_intro"
	},
	{
	  "conditions": [
        "old_key_quest_active"
	  ],
	  "start": "quest_active_intro"
	},
	{
	  "conditions": [
        "talked_to_old_man"
	  ],
	  "start": "returning_player"
	}
  ],

  "nodes": {
	"first_meeting": {
	  "text": "I don't think we've met before. What's your name?",
	  "choices": [
		{
		  "text": "My name is {player_name}.",
		  "next": "introduction"
		},
		{
		  "text": "I'd rather not say.",
		  "next": "refuse_name"
		}
	  ]
	},

	"introduction": {
	  "text": "Nice to meet you, {player_name}. I'll remember that.",
	  "events": [
        "old_man_met_player"
	  ],
	  "end": true
	},

	"refuse_name": {
	  "text": "That's alright. Maybe another time.",
	  "events": [
        "old_man_met_player"
	  ],
	  "end": true
	},

	"returning_player": {
	  "text": "Good to see you again, {player_name}. I could use some help.",
	  "choices": [
		{
		  "text": "What happened?",
		  "next": "offer_quest"
		},
		{
		  "text": "I have to go.",
		  "next": "leave"
		}
	  ]
	},

	"offer_quest": {
	  "text": "I lost an old key somewhere nearby. Could you find it?",
	  "choices": [
		{
		  "text": "I'll look for it.",
		  "next": "accept_quest"
		},
		{
		  "text": "Not right now.",
		  "next": "decline_quest"
		}
	  ]
	},

	"accept_quest": {
	  "text": "Thank you. It means a lot to me.",
	  "events": [
        "old_key_quest_started"
	  ],
	  "end": true
	},

	"decline_quest": {
	  "text": "I understand. Let me know if you change your mind.",
	  "end": true
	},

	"quest_active_intro": {
	  "text": "Have you found my old key yet?",
	  "choices": [
		{
		  "text": "Not yet.",
		  "next": "not_found"
		},
		{
		  "text": "I have to go.",
		  "next": "leave"
		}
	  ]
	},

	"key_found_intro": {
	  "text": "Is that my old key in your hand?",
	  "choices": [
		{
		  "text": "Give the old key.",
		  "next": "give_key",
		  "conditions": [
			"has_old_key",
            "!key_already_given"
		  ]
		},
		{
		  "text": "Keep it for now.",
		  "next": "keep_key"
		}
	  ]
	},

	"give_key": {
	  "text": "You found it. Thank you.",
	  "events": [
		"old_key_given",
        "old_key_quest_completed"
	  ],
	  "end": true
	},

	"quest_completed_intro": {
	  "text": "Thanks again for bringing my key back, {player_name}.",
	  "choices": [
		{
		  "text": "You're welcome.",
		  "next": "welcome"
		},
		{
		  "text": "Leave.",
		  "next": "leave"
		}
	  ]
	},

	"not_found": {
	  "text": "Please keep looking. It must be somewhere nearby.",
	  "end": true
	},

	"keep_key": {
	  "text": "Why are you holding onto it?",
	  "end": true
	},

	"welcome": {
	  "text": "I won't forget what you did.",
	  "end": true
	},

	"leave": {
	  "text": "Take care, {player_name}.",
	  "end": true
	}
  }
}
